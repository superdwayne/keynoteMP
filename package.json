{
  "name": "keynote-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Apple Keynote automation via AppleScript/JXA",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "keynote-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin"
  ],
  "license": "MIT"
}
